---
import { Image } from 'astro:assets'

import { twMerge } from 'tailwind-merge'

import logo from '@/images/common/logo.png'

const { class: className = '' } = Astro.props

const menu = [
  {
    label: 'Home',
    href: '/',
  },
  {
    label: 'About',
    href: '/about',
  },
  {
    label: 'Services',
    href: '/services',
  },
  {
    label: 'Portfolio',
    href: '/portfolio',
  },
  {
    label: 'Blog',
    href: '/blog',
  },
  {
    label: 'Contact',
    href: '/contact',
  },
]
---

<nav
  role="navigation"
  class={twMerge(
    '@container container grid items-center grid-flow-row-dense h-full grid-cols-[1fr_auto_1fr] sm:grid-cols-[repeat(3,1fr)_auto_repeat(3,1fr)] grid-rows-(--header-height)',
    className
  )}>
  <a href={Astro.url.origin} class="col-start-2 h-full sm:col-start-4">
    <Image
      src={logo}
      alt="Tessa Morgan Photographer"
      width={279}
      height={101}
      fetchpriority="high"
      loading="eager"
      class="h-full w-auto object-contain"
    />
  </a>
  <button
    type="button"
    id="gnav-trigger"
    aria-controls="gnav"
    aria-expanded="false"
    aria-haspopup="dialog"
    aria-label="メニューを開く"
    class="-col-end-1 aspect-square h-full w-auto justify-self-end sm:hidden">
    <svg
      width="60"
      height="60"
      viewBox="0 0 60 60"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="h-full w-full">
      <path
        d="M16 20H44M22.8108 30H44M32.6486 40H44"
        stroke="black"
        stroke-width="1"
        stroke-linecap="round"></path>
    </svg>
  </button>
  <dialog id="gnav" class="max-sm:bg-white/80 max-sm:px-5 sm:contents">
    <ul class="sm:contents">
      {
        menu.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="grid h-full w-full place-content-center py-4 text-[0.785rem] text-gray-700 uppercase">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </dialog>
</nav>

<style>
  @reference '@/styles/main.css';

  #gnav-trigger {
    anchor-name: --trigger-anchor;
  }

  #gnav {
    position-anchor: --trigger-anchor;

    @variant max-sm {
      @apply absolute top-[anchor(bottom)] right-[anchor(right)] bottom-auto left-auto m-0 h-fit w-max transition-[opacity,height] transition-discrete duration-300 starting:h-0 starting:opacity-0;
      @apply backdrop:opacity-0 backdrop:transition-opacity open:backdrop:opacity-100 starting:backdrop:opacity-0;

      &:not(:open) {
        @apply pointer-events-none block h-0 opacity-0;
      }
    }
  }
</style>

<script>
  const initGnav = (trigger: HTMLButtonElement) => {
    const gnavId = trigger.getAttribute('aria-controls')
    if (!gnavId) return

    const gnav = document.getElementById(gnavId)
    if (!(gnav instanceof HTMLDialogElement)) return

    const breakpoint = getComputedStyle(document.documentElement)
      .getPropertyValue('--breakpoint-sm')
      .trim()
    const mediaQuery = window.matchMedia(`(min-width: ${breakpoint})`)

    const syncUi = () => {
      trigger.setAttribute('aria-expanded', String(gnav.open))
      trigger.setAttribute(
        'aria-label',
        gnav.open ? 'メニューを閉じる' : 'メニューを開く'
      )
      gnav.toggleAttribute('data-scroll-lock', gnav.open)
    }

    const setNavVisibility = () => {
      if (mediaQuery.matches && gnav.open) {
        gnav.close()
      }
      syncUi()
    }

    mediaQuery.addEventListener('change', setNavVisibility)
    setNavVisibility()

    trigger.addEventListener('click', () => {
      if (mediaQuery.matches) return

      if (gnav.open) {
        gnav.close()
      } else {
        gnav.show()
      }
    })

    gnav.addEventListener('close', syncUi)
    gnav.addEventListener('open', syncUi)

    // リンクがクリックされたら閉じる
    gnav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (!mediaQuery.matches && gnav.open) {
          gnav.close()
        }
      })
    })
  }

  const trigger = document.getElementById('gnav-trigger')
  if (trigger instanceof HTMLButtonElement) {
    initGnav(trigger)
  }
</script>
