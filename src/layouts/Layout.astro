---
import '@/styles/main.css'
import { Font } from 'astro:assets'

import { SEO } from 'astro-seo'

import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'

export interface Props {
  title?: string
  description?: string
  ogp?: {
    type?: string
    image?: string
    url?: string
  }
}

const { title = '', description = '', ogp = {} } = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Font cssVariable="--font-garamond" preload />
    <Font cssVariable="--font-raleway" preload />
    <Font cssVariable="--font-ephesis" preload />
    <SEO
      title={title}
      titleTemplate=`%s | Tessa Morgan`
      titleDefault={'Tessa Morgan'}
      description={description || 'デモサイトです'}
      canonical={Astro.site?.origin + Astro.url.pathname}
      openGraph={{
        basic: Object.assign(
          {
            title,
            type: 'website',
            image: Astro.site?.origin + '/ogp.png',
            url: Astro.site?.origin + Astro.url.pathname,
          },
          ogp
        ),
      }}
    />
  </head>
  <body class="">
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<script>
  ;(() => {
    const afterPaint = (callback: () => void) => {
      requestAnimationFrame(() => {
        requestAnimationFrame(callback)
      })
    }

    const fadein = () => {
      const elements = document.querySelectorAll('[data-fade-in]')
      if (!elements.length) return

      const reveal = (element: Element) => {
        afterPaint(() => {
          element.setAttribute('data-fade-in', 'shown')
        })
      }

      const observer = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              reveal(entry.target)
              observer.unobserve(entry.target)
            }
          })
        },
        {
          threshold: 0.25,
        }
      )

      afterPaint(() => {
        elements.forEach((element) => observer.observe(element))
      })
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fadein)
    } else {
      fadein()
    }
  })()
</script>

<style is:global>
  @reference '@/styles/main.css';

  [data-fade-in] {
    @apply transition-[opacity,translate] duration-1000 motion-reduce:transition-none;

    &:not([data-fade-in='shown']) {
      @apply opacity-0;
    }
  }

  [data-fade-in='shown'] {
    @apply translate-x-0 translate-y-0 opacity-100;
  }

  [data-fade-in='toTop'] {
    @apply translate-y-[min(15%,3cqi)];
  }
</style>
